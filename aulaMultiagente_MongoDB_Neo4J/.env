# Copie este arquivo para .env  ->  cp .env.example .env
# O arquivo .env NÃO vai para o Git (está no .gitignore).

# Senha do Neo4j (mínimo 8 caracteres). Usuário fixo: neo4j
NEO4J_PASSWORD=senhaForte123

# Pares de moedas a coletar (separados por vírgula, SEM espaços)
PARES=USD-BRL,EUR-BRL,EUR-USD,BTC-BRL,GBP-BRL,JPY-BRL

# Intervalo entre coletas, em segundos (300 = 5 minutos)
INTERVALO_SEGUNDOS=300
